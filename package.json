{
  "name": "encrypted-bookmark",
  "version": "1.4.0",
  "description": "Local-first, privacy-focused bookmark manager with encryption",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:ui": "npm run build && playwright test --ui",
    "test:e2e:headed": "npm run build && playwright test --headed",
    "test:e2e:debug": "npm run build && playwright test --debug",
    "test:e2e:report": "playwright show-report e2e/playwright-report"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-window": "^2.2.7"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.23",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.42.0",
    "@types/chrome": "^0.0.258",
    "@types/react": "^18.2.47",
    "@types/react-dom": "^18.2.18",
    "@types/react-window": "^1.8.8",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^5.0.11"
  }
}
